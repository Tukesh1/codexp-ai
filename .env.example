# CodeExp AI — Environment Variables

# Database
POSTGRES_USER=codeexp
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=codeexp
DATABASE_URL=postgresql://codeexp:secure_password@localhost:5432/codeexp?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Go API
GO_ENV=development
JWT_SECRET=dev-jwt-secret-change-me
PORT=8080

# Auth (Clerk — optional in local/dev; use /api/v1/auth/dev-login instead)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# GitHub (optional)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Personal access token — raises API rate limit from 60/hr to 5,000/hr (recommended for overview stats)
GITHUB_TOKEN=
# AI Service
PYTHON_ENV=development
HUGGINGFACE_API_KEY=
MODEL_CACHE_DIR=./models
SKIP_HEAVY_MODELS=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# AI service URL used by Go API for ask/docs
AI_SERVICE_URL=http://localhost:8000

# Payments (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
